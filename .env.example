# Copy this file to .env and fill in your credentials.
# .env is gitignored — your keys are never committed.

# ── Azure OpenAI (GPT summarisation) ─────────────────────────────────────────
OPENAI_API_KEY=<your Azure OpenAI key>
AZURE_OPENAI_ENDPOINT=https://<your-resource>.openai.azure.com/
AZURE_OPENAI_API_VERSION=2024-02-01
VIDEO2DOCS_LLM_MODEL=gpt-4.1
USE_OPENAI=1

# ── Azure Whisper (transcription) ─────────────────────────────────────────────
AZURE_WHISPER_ENDPOINT=https://<your-resource>.cognitiveservices.azure.com
AZURE_WHISPER_KEY=<your Whisper key>

# ── Web UI ────────────────────────────────────────────────────────────────────
ADMIN_USER=admin
ADMIN_PASS=changeme
SECRET_KEY=change-me-to-a-random-string
OUTPUT_DIR=output
VIDEO2DOCS_LANGUAGE=en-US
HOST=127.0.0.1
PORT=5001
FLASK_DEBUG=0
PREFETCH_LLM_MODELS=0
